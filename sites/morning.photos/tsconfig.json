{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "lib": ["ESNext"],
    "jsx": "preserve",
    "strictNullChecks": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "paths": {
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": ["src/", "../../shared/"]
}
