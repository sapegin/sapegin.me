  "keywords": [],
  "notes": [
    "For nuts, I like to use pecans, almonds, dried apricots, dried cranberries, and dried rhubarb. Experiment and find what you like."
  ],
  "overnight": false,
  "slug": "banana-bread",
  "source": "This recipe is inspired by the [Banana banana bread](https://www.allrecipes.com/recipe/20144/banana-banana-bread/) recipe.",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Preheat oven to 180C.",
          "pause": false
        },
        {
          "text": "Butter the baking form.",
          "pause": false
        },
        {
          "text": "In a medium bowl, combine <Ingredient name=\"all-purpose flour\"  />, <Ingredient name=\"baking powder\"  />,  <Ingredient name=\"cinnamon\"  />, and <Ingredient name=\"salt\"  />, using a whisk.",
          "pause": false
        },
        {
          "text": "In a mixer bowl, mix butter and <Ingredient name=\"coconut sugar\"  />, using a mixer with a whisk attachment.",
          "pause": false
        },
        {
          "text": "In a separate small bowl, break <Ingredient name=\"egg\"  />.",
          "pause": false
        },
        {
          "text": "Incorporate eggs one by one into the butter and sugar mixture using a mixer.",
          "pause": false
        },
        {
          "text": "While eggs are mixed, in yet another medium bowl, puree bananas using a masher or fork.",
          "pause": false
        },
        {
          "text": "Incorporate bananas into the mixture, using a silicone spatula.",
          "pause": false
        },
        {
          "text": "Add nuts and dried fruits to the mixture.",
          "pause": false
        },
        {
          "text": "Add the dry ingredients to the wet mixture. Stir using a silicone spatula just enough to wet the flour.",
          "pause": false
        },
        {
          "text": "Pour the batter into the baking form.",
          "pause": false
        },
        {
          "text": "Bake for 60-80 minutes, until a toothpick comes out dry.",
          "pause": false
        },
        {
          "text": "Let the bread cool down, and remove it from the baking form.",
          "pause": false
        }
      ]
    }
  ],
