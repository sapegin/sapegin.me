  "notes": [
    "The use of chili to prepare frijoles refritos is optional, it was the way of Margarita’s grandma. "
  ],
  "overnight": true,
  "slug": "frijoles-refritos",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Soak the beans overnight.",
          "pause": true
        },
        {
          "text": "Cook the beans in lightly salted water on medium heat until tender.",
          "pause": false
        },
        {
          "text": "Cool down the beans in their cooking liquid.",
          "pause": false
        },
        {
          "text": "Cook the chili on a skillet with a bit of olive oil on medium heat, until blistered on all sides.",
          "pause": false
        },
        {
          "text": "Add the beans to the skillet with a bit of their cooking liquid (keep about 1 cup separately), cover, and bring to a boil.",
          "pause": false
        },
        {
          "text": "Smash the beans and the chili using a masher until there are very few whole beans left.",
          "pause": false
        },
        {
          "text": "Reduce or add more liquid to achieve the desired consistency.",
          "pause": false
        }
      ]
    }
  ],
