  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Preheat oven to 180C. Line a baking sheet with parchment paper.",
          "pause": false
        },
        {
          "text": "Melt <Ingredient name=\"coconut oil\"  /> and let it cool a bit.",
          "pause": false
        },
        {
          "text": "In a large bowl, combine <Ingredient name=\"oat\"  />, <Ingredient name=\"salt\"  />, and <Ingredient name=\"cinnamon\"  />. Mix everything.",
          "pause": false
        },
        {
          "text": "Pour in the coconut oil, <Ingredient name=\"maple syrup\"  />, and <Ingredient name=\"chicory syrup\"  />. Mix well, until every oat is lightly coated.",
          "pause": false
        },
        {
          "text": "Evenly distribute the granola on the baking sheet using a silicone spatula or a large spoon.",
          "pause": false
        },
        {
          "text": "Bake for 8 minutes, stir, bake for another 5-8 minutes, until golden but not dark.",
          "pause": false
        },
        {
          "text": "Let the granola cool completely.",
          "pause": false
        },
        {
          "text": "Cut the dates into small pieces, and mix with the granola.",
          "pause": false
        }
      ]
    }
  ],
