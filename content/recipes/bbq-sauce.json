  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Prepare the vegetables. **Onion:** cut into small dice. **Chili:** halve lengthwise, remove the seeds and thinly slice. **Tomatoes:** roughly chop. **Bell pepper:** remove the seeds and roughly chop. **Garlic:** chop into small pieces.",
          "pause": false
        },
        {
          "text": "In a medium saucepan, sauté on medium heat 1/2 of the diced onions and chili until transparent, for about 5 minutes.",
          "pause": false
        },
        {
          "text": "Add tomatoes, bell pepper, and garlic, and cook on low heat for about 20 minutes.",
          "pause": false
        },
        {
          "text": "Add <Ingredient name=\"tomato paste\"  />, and <Ingredient name=\"mustard\"  />.",
          "pause": false
        },
        {
          "text": "Season with smoked paprika powder, black pepper, cumin, and salt.",
          "pause": false
        },
        {
          "text": "Mix everything into a paste using a blender.",
          "pause": false
        },
        {
          "text": "Add raw onions, and mix using a spoon.",
          "pause": false
        }
      ]
    }
  ],
