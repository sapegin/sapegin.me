      "steps": [
        {
          "text": "Trim sides of the cucumber, remove the seeds, and grate it on a medium side of a grater into a medium bowl. Grate the short side of the cucumber, so the pieces aren’t too long.",
          "pause": false
        },
        {
          "text": "Peel the garlic and press it into the bowl with the cucumber.",
          "pause": false
        },
        {
          "text": "Juice the lime into the bowl.",
          "pause": false
        },
        {
          "text": "Remove stems of the dill and finely chop the fronds. Add chopped fronds into the bowl.",
          "pause": false
        },
        {
          "text": "Add yogurt into the bowl, and mix everything.",
          "pause": false
        }
      ]
    }
