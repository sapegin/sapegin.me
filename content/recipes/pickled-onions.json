  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Halve the onion and cut it into 1/4 cm slices.",
          "pause": false
        },
        {
          "text": "Quarter the chili lengthwise and cut it into very thin slices.",
          "pause": false
        },
        {
          "text": "Put the onions and the chili into a bowl.",
          "pause": false
        },
        {
          "text": "Juice the lime, and add <Ingredient name=\"vinegar\"  /> into the bowl, and mix again.",
          "pause": false
        },
        {
          "text": "Add salt, thoroughly mix, and add more salt if needed.",
          "pause": false
        },
        {
          "text": "Leave the container to pickle on the counter for at least 30 minutes (the more, the better).",
          "pause": false
        }
      ]
    }
