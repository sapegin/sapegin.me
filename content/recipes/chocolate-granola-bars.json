  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Cook the chocolate ganache, but add more chocolate and less cream to make it harder.",
          "pause": false
        },
        {
          "text": "Line a baking form with baking paper.",
          "pause": false
        },
        {
          "text": "Cut the dried pineapples into 1/2 cm pieces.",
          "pause": false
        },
        {
          "text": "Pour 3/4 of the chocolate ganache into the baking form.",
          "pause": false
        },
        {
          "text": "Sprinkle the granola over the chocolate ganache.",
          "pause": false
        },
        {
          "text": "Sprinkle the dried pineapples over the granola.",
          "pause": false
        },
        {
          "text": "Sprinkle the rest of the chocolate ganache over the granola and dried fruits.",
          "pause": false
        },
        {
          "text": "Refrigerate for at least 30 minutes.",
          "pause": false
        },
        {
          "text": "Remove from the baking form, and cut into equal pieces.",
          "pause": false
        }
      ]
    }
