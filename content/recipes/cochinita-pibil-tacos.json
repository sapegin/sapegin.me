  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Warm up the tortillas: heat a non-sticking or cast iron skillet on medium-high until hot (don’t add oil). Warm the tortillas one by one: for about 30 seconds on one side, then for about one minute on the other side, then flip again and cook a bit more, until crispy but still slightly flexible (they shouldn’t be too soft because the meat is very juicy, and they may break).",
          "pause": false
        },
        {
          "text": "Serve all the ingredients — tortillas, avocado, cochinita pibil, pickled onions, frijoles refritos, and salsa roja tatemada — separately, so everyone could assemble the taco of their dreams (this also prevents tortillas to become soaked and break).",
          "pause": false
        }
      ]
    }
