  "slug": "caprese-salad-with-pesto",
  "steps": [
    {
      "name": "To make the pesto",
      "steps": [
        {
          "text": "Pick basil and parsley leaves (only good ones, without black spots and not too wilted), wash them and roughly chop.",
          "pause": false
        },
        {
          "text": "Peel and roughly chop garlic.",
          "pause": false
        },
        {
          "text": "Grate parmesan.",
          "pause": false
        },
        {
          "text": "Mix basil, parsley, garlic, sunflower seeds, parmesan cheese, olive oil using a blender or a food processor until all bigger chunks are chopped. It shouldn’t be too smooth and creamy either: it’s nice when pesto has a rustic texture.",
          "pause": false
        },
        {
          "text": "Season with salt and pepper.",
          "pause": false
        }
      ]
    },
    {
      "name": "To make the salad",
      "steps": [
        {
          "text": "Slice the tomatoes into 1/2 cm slices, remove kernels.",
          "pause": false
        },
        {
          "text": "Slice the Mozzarella into the same amount of slices as you have tomato slices.",
          "pause": false
        },
        {
          "text": "Arrange the tomato slices on a plate, top with the Mozzarella slices and the pesto.",
          "pause": false
        }
      ]
    }
  ],
