  "keywords": [],
  "notes": [
    "A mix of pumpkins and winter squashes works best for this recipe.",
    "For dried chilies, we prefer a mix of jalapeño and habanero flakes.",
    ""
  ],
  "overnight": false,
  "slug": "roasted-pumpkin-soup",
  "source": "This recipe is based on J. Kenji Lopez-Alt’s book “The Food Lab: Better Home Cooking Through Science”",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Preheat oven to 180C. Line a baking sheet with parchment paper.",
          "pause": false
        },
        {
          "text": "Halve the pumpkins lengthwise, scoop out and discard the seeds using a large spoon.",
          "pause": false
        },
        {
          "text": "Put the pumpkins onto the baking sheet cut side up. Rub all over with olive oil and season with salt and pepper. Roast until the flesh is very tender and shows no resistance when poked with a sharp knife, for about 1 hour.",
          "pause": true
        },
        {
          "text": "While the pumpkins are roasting, peel the onion, halve, and cut into 1/2 cm slices.",
          "pause": false
        },
        {
          "text": "When the pumpkins are ready, remove them from the oven, and cool down.",
          "pause": false
        },
        {
          "text": "While the pumpkins are cooling, melt the butter in a large pot over medium-low heat.",
          "pause": false
        },
        {
          "text": "Add the onion to the pot. Cook, frequently stirring, until transparent, for several minutes.",
          "pause": false
        },
        {
          "text": "Add <Ingredient name=\"cinnamon\"  />, <Ingredient name=\"nutmeg\"  />, <Ingredient name=\"cumin seeds\"  />, and chili flakes to the pot, and stir until fragrant, for about 30 seconds.",
          "pause": false
        },
        {
          "text": "Add the chicken stock to the pot.",
          "pause": false
        },
        {
          "text": "Using a large spoon, carefully scoop out the roasted pumpkin flesh, and transfer it to the pot.",
          "pause": false
        },
        {
          "text": "Add enough water to barely cover the pumpkin and bring it to a boil.",
          "pause": false
        },
        {
          "text": "Puree the soup using a blender until completely smooth. Add more stock or water to achieve the desired consistency. Add more salt and pepper if needed.",
          "pause": false
        },
        {
          "text": "Stir in the maple syrup, and serve.",
          "pause": false
        }
      ]
    }
  ],
