  "steps": [
    {
      "name": "To cook the chicken",
      "steps": [
        {
          "text": "Rinse the chicken parts.",
          "pause": false
        },
        {
          "text": "Chop achiote into small pieces.",
          "pause": false
        },
        {
          "text": "Juice the lime, and mix it with the achiote until the achiote is fully diluted.",
          "pause": false
        },
        {
          "text": "Peel the garlic, and press it into the mix.",
          "pause": false
        },
        {
          "text": "Liberally season with salt.",
          "pause": false
        },
        {
          "text": "Rub the chicken parts with the marinade mixture.",
          "pause": false
        },
        {
          "text": "Refrigerate in an airtight container for at least 4 hours, better overnight.",
          "pause": true
        },
        {
          "text": "If using an oven, preheat it to 210C.",
          "pause": false
        },
        {
          "text": "Roast in an air fryer at 210C for 20 minutes, turn the legs and wings after 10 minutes, and remove the legs after 15 minutes. (Or roast in the oven at 210C for about 40 minutes.)",
          "pause": false
        }
      ]
    },
    {
      "name": "To cook the potatoes",
      "steps": [
        {
          "text": "If using an oven, preheat it to 210C.",
          "pause": false
        },
        {
          "text": "Cut the potatoes into chunky wedges (don't peel them).",
          "pause": false
        },
        {
          "text": "In a large wide bowl, put the potatoes, and liberally sprinkle them with olive oil, and a couple of pinches of salt.",
          "pause": false
        },
        {
          "text": "Grind the spices: <Ingredient name=\"cumin seeds\"  />, <Ingredient name=\"coriander seeds\"  />, <Ingredient name=\"fennel seeds\"  />, and <Ingredient name=\"chile flakes\"  />. Add the spices to the bowls with the potatoes.",
          "pause": false
        },
        {
          "text": "Thoroughly mix everything using your hands.",
          "pause": false
        },
        {
          "text": "Roast in an air fryer in two batches (to avoid overcrowding and steaming instead of baking) at 210C for 18 minutes, and give it a shake in the middle. (Or roast in the oven at 210C for about 40 minutes.)",
          "pause": false
        }
      ]
    }
  ],
