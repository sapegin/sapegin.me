  "keywords": [],
  "notes": [
    "Try it with different berries, or add other berries to the blueberries. A mix of blueberries, blackberries, and strawberries works very, very well…"
  ],
  "overnight": false,
  "slug": "blueberry-cobbler",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "In a baking form, mix berries with two tablespoons of coconut sugar (about 25 g), and leave for about 30 minutes.",
          "pause": false
        },
        {
          "text": "Preheat oven to 200C.",
          "pause": false
        },
        {
          "text": "Mix dry ingredients: <Ingredient name=\"all-purpose flour\"  />, <Ingredient name=\"spelt flour\"  />, <Ingredient name=\"almond flour\"  />, and the remaining 50 g of coconut sugar.",
          "pause": false
        },
        {
          "text": "Mix in the butter with your hand until all butter is absorbed and there’s almost no dry flour left.",
          "pause": false
        },
        {
          "text": "Take the dough by a handful, squeeze it to compress, and spread on top of the berries as small crumbs.",
          "pause": false
        },
        {
          "text": "Bake for 25-30 minutes, until golden-brown.",
          "pause": false
        }
      ]
    }
  ],
