  "steps": [
    {
      "name": "To cook the gremolata",
      "steps": [
        {
          "text": "Prepare the ingredients. **Jalapeño:** dice into small dice. **Greens:** finely chop.",
          "pause": false
        },
        {
          "text": "In a small bowl, add jalapeño, greens, and mustard, press the garlic, zest and juice the lime. Mix thoroughly.",
          "pause": false
        },
        {
          "text": "Season with salt and pepper.",
          "pause": false
        }
      ]
    },
    {
      "name": "To cook the potatoes",
      "steps": [
        {
          "text": "Wash and clean potatoes.",
          "pause": false
        },
        {
          "text": "Cook potatoes in water with a lot of salt, until soft (but not too soft — a knife should enter with a bit of resistance).",
          "pause": false
        },
        {
          "text": "Preheat oven to 240C.",
          "pause": false
        },
        {
          "text": "When the potatoes are cooked, drain them in a colander.",
          "pause": false
        },
        {
          "text": "Using a flat-bottomed glass, gently smash the potatoes.",
          "pause": false
        },
        {
          "text": "Place the potatoes onto a baking tray.",
          "pause": false
        },
        {
          "text": "Drizzle the potatoes with olive oil, and add more salt if needed.",
          "pause": false
        },
        {
          "text": "Bake the potatoes until golden, for about 30 minutes. Turn the potatoes, and bake until golden on the other side, for about 20 minutes more.",
          "pause": false
        },
        {
          "text": "Serve topped with the gremolata.",
          "pause": false
        }
      ]
    }
  ],
