  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Rinse the peas in cold water, and cook in water until tender (but not too soft).",
          "pause": false
        },
        {
          "text": "While the peas are cooking, prepare the vegetables. **Tomatoes, bell peppers:** cut into medium dice. **Onion:** peel, deroot, and cut into medium dice. **Chile:** cut lengthwise, remove seeds, and thinly slice. **Scallion:** thinly slice both green and white parts. **Parsley:** coarsely chop.",
          "pause": false
        },
        {
          "text": "Whisk together lime juice, olive oil, and salt until they form an emulsion.",
          "pause": false
        },
        {
          "text": "Combine peas, all the vegetables, and the dressing. Thoroughly mix.",
          "pause": false
        }
      ]
    }
  ],
