  "steps": [
    {
      "name": "To cook the mashed potatoes",
      "steps": [
        {
          "text": "Peel the potatoes, cut them into large chunks of similar size, and cook in water with <Ingredient name=\"bay leaf\"  /> and salt, until tender.",
          "pause": false
        },
        {
          "text": "Keep about 1 cup of potato cooking liquid, and discard the remaining cooking liquid.",
          "pause": false
        },
        {
          "text": "Mash the potatoes using a potato ricer or masher, add <Ingredient name=\"egg\"  />, a few tablespoons of butter, a splash of milk, and salt. Keep adding more cooking liquid and milk and stirring until the potatoes are creamy.",
          "pause": false
        },
        {
          "text": "Add more salt if needed.",
          "pause": false
        }
      ]
    },
    {
      "name": "To cook the filling",
      "steps": [
        {
          "text": "Turn on the oven to 220C (so it's hot enough by the time we're ready to bake the pie).",
          "pause": false
        },
        {
          "text": "While the potatoes are cooking, prepare the vegetables. **Onion:** peel, halve and cut into thin slices. **Garlic:** peel and cut into 1/2 cm pieces. **Chiles:** halve, remove the seeds, and thinly slice. **Carrots:** peel (if needed), halve, and cut into 1/2 cm slices. **Zucchini:** halve, and cut into 1/4 cm half-moons. **Green beans:** cut the ends, and cut into 3-4 cm pieces. **Sugar pees:** halve.",
          "pause": false
        },
        {
          "text": "Dilute <Ingredient name=\"kimchi paste\"  /> in 1/4 cup of water.",
          "pause": false
        },
        {
          "text": "On a medium-sized skillet sat on medium heat with olive oil, sauté onions, garlic, and chili, until the onion is transparent, for a few minutes.",
          "pause": false
        },
        {
          "text": "On a second, larger oven-safe skillet sat on medium-high heat with a bit of olive oil, start frying carrots, until they start to soften, for about 5 minutes.",
          "pause": false
        },
        {
          "text": "Add the ground meat to the small skillet, stir, and keep cooking until there are no pink spots in the meat.",
          "pause": false
        },
        {
          "text": "Add the zucchini, and green beans to the large skillet, and cook for another 5 minutes.",
          "pause": false
        },
        {
          "text": "Add the sugar peas to the large skillet, and cook for a few more minutes.",
          "pause": false
        },
        {
          "text": "Add the diluted kimchi paste and a splash of soy sauce to the meat, reduce the heat to low, and cook for about 5 minutes. Remove the skillet from heat.",
          "pause": false
        },
        {
          "text": "Add the meat to the large skillet, thoroughly mix everything, and add more salt if needed.",
          "pause": false
        }
      ]
    },
    {
      "name": "To cook the pie",
      "steps": [
        {
          "text": "Put the mashed potatoes on top of the filling in the large skillet in an even layer.",
          "pause": false
        },
        {
          "text": "Bake the pie uncovered for about 40 minutes in the oven, until golden.",
          "pause": false
        }
      ]
    }
  ],
