      "name": "",
      "steps": [
        {
          "text": "Prepare the vegetables. **Tomatoes:** remove the kernel and quarter. **Garlic:** peel and roughly cut. **Basil:** pick leaves without black spots and not too wilted.",
          "pause": false
        },
        {
          "text": "Put the tomatoes, garlic, tomato paste, olive oil, salt, dried rosemary, and black pepper into the blender, and mix until you have smooth uniform liquid.",
          "pause": false
        },
        {
          "text": "Add the basil and briefly pulse to chop the basil just a bit.",
          "pause": false
        },
        {
          "text": "Add more salt and black pepper if needed.",
          "pause": false
        }
      ]
    }
