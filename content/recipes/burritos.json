    {
      "name": "",
      "steps": [
        {
          "text": "Cut the cheese into not-so-thin slices.",
          "pause": false
        },
        {
          "text": "Warm up the tortillas on a large dry skillet.",
          "pause": false
        },
        {
          "text": "Assemble the burritos: spread the frijole sauce in the middle-low section of the tortilla, distribute the picadillo on top, and put the cheese on top of the picadillo. Now roll the tortilla: flip the lower part over the filling, flip the sides, and tightly roll from the bottom.",
          "pause": false
        },
        {
          "text": "Repeat for the remaining tortillas.",
          "pause": false
        },
        {
          "text": "Briefly toast the burritos on a skillet on all sides.",
          "pause": false
        }
      ]
