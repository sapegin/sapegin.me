  "source": "This recipe is based on the cold borsch recipe from Vlad Piskunov’s book “Russian cuisine. Best in 500 years”.",
  "steps": [
    {
      "name": "To cook the beet broth",
      "steps": [
        {
          "text": "Peel the beets and shred them in a food processor or grate on a grater.",
          "pause": false
        },
        {
          "text": "Cook in 3 liters of water for about 45 minutes, once the water is boiling.",
          "pause": false
        },
        {
          "text": "While the beets are cooking, thinly slice the horseradish or ginger.",
          "pause": false
        },
        {
          "text": "Add the ginger to the cooking beets, and cook the beets for 15 minutes more.",
          "pause": false
        },
        {
          "text": "Let the beet broth cool completely.",
          "pause": false
        },
        {
          "text": "Filter the beet broth using a sieve.",
          "pause": false
        },
        {
          "text": "Season with salt, sugar, and lime juice.",
          "pause": false
        }
      ]
    },
    {
      "name": "To cook the borsch",
      "steps": [
        {
          "text": "Preheat oven to 200C.",
          "pause": false
        },
        {
          "text": "Distribute unpeeled young beats on the baking sheet, and drizzle them with olive oil and salt.",
          "pause": false
        },
        {
          "text": "Roast beets until tender (so you could easily insert a knife or a fork).",
          "pause": false
        },
        {
          "text": "While the beets are roasting, cut the beet stems into 1 cm slices.",
          "pause": false
        },
        {
          "text": "Cool down the roasted beets, and peel them.",
          "pause": false
        },
        {
          "text": "In a medium saucepan, add beet stems and about 100 ml of water and <Ingredient name=\"vinegar\"  />. Cook the beet stems for about 10 minutes, until tender.",
          "pause": false
        },
        {
          "text": "Discard the water of beet stems, and cool the stems down.",
          "pause": false
        },
        {
          "text": "Cut the roasted beets, cucumbers, and radishes into 1 cm cubes.",
          "pause": false
        },
        {
          "text": "Slice the spring onions, and thinly chop the dill.",
          "pause": false
        },
        {
          "text": "Combine beet stems, roasted beets, cucumbers, radishes, spring onions, and dill.",
          "pause": false
        },
        {
          "text": "Add the beet broth, and thoroughly mix everything.",
          "pause": false
        },
        {
          "text": "Cook the eggs in water, for 9 minutes after the water starts to boil. Remove the eggs from the water and transfer them to a bowl with cold water to cool them down and make peeling easier.",
          "pause": false
        },
        {
          "text": "Serve the soup with a tablespoon of smetana (or crème fraîche) and a halved hardboiled egg.",
          "pause": false
        }
      ]
    }
  ],
