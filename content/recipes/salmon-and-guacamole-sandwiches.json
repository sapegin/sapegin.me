  "steps": [
    {
      "name": "To make the guacamole",
      "steps": [
        {
          "text": "Peel avocados (cut all the way around the stone using a paring knife, then remove the stone and scoop the flesh using a spoon), put them into a medium-sized bowl, and smash them using a small masher or a fork.",
          "pause": false
        },
        {
          "text": "Halve the tomato, remove the root and cut into 1/4 cm cubes, put into a bowl with avocados.",
          "pause": false
        },
        {
          "text": "Peel the onion and cut 1/2 into small dice, add into the bowl.",
          "pause": false
        },
        {
          "text": "Quarter the chili lengthwise, remove the seeds, thinly slice each quarter, and add the chilies into the bowl.",
          "pause": false
        },
        {
          "text": "Discard large stems of the parsley and finely chop the rest, add the chopped parsley into the bowl.",
          "pause": false
        },
        {
          "text": "Juice one lime into the bowl.",
          "pause": false
        },
        {
          "text": "Add salt, and thoroughly mix everything.",
          "pause": false
        }
      ]
    },
    {
      "name": "For the sandwiches",
      "steps": [
        {
          "text": "Slice the bread.",
          "pause": false
        },
        {
          "text": "Spread guacamole over each slice of bread.",
          "pause": false
        },
        {
          "text": "Put a few slices of salmon on top of each sandwich.",
          "pause": false
        }
      ]
    }
  ],
