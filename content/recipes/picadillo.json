  "notes": [
    "If you find fresh Serrano chilies, they are the best option for this picadillo. You can also replace the fresh chili with chili flakes, or mix a fresh chili with flakes to reach the level of spiciness you like.",
    "If you want to increase the amount, try to add a couple of new potatoes together with carrots."
  ],
  "overnight": false,
  "slug": "picadillo",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Prepare the vegetables. **Onion, chili, garlic, and carrot:** peel, and cut into small dice.",
          "pause": false
        },
        {
          "text": "In a large skillet set on medium fire with a generous amount of olive oil, sauté the onion and the garlic, until the onion is transparent.",
          "pause": false
        },
        {
          "text": "Add the chili and stir for a couple of minutes.",
          "pause": false
        },
        {
          "text": "Add the carrots, and cook for about 5 minutes.",
          "pause": false
        },
        {
          "text": "Add the ground meat. Season with salt, and ground cumin. Cook stirring occasionally until there are no pink spots on the meat.",
          "pause": false
        },
        {
          "text": "Add the peas, and cook stirring occasionally until the peas are warm.",
          "pause": false
        },
        {
          "text": "Add more salt if needed.",
          "pause": false
        }
      ]
    }
  ],
