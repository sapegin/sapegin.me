  "keywords": [],
  "notes": [],
  "overnight": false,
  "slug": "easy-bread",
  "source": "This recipe is based on the [peasant bread recipe](https://alexandracooks.com/2012/11/07/my-mothers-peasant-bread-the-best-easiest-bread-you-will-ever-make/) by Alexandra Stafford.",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "In a large bowl, whisk together <Ingredient name=\"all-purpose flour\"  />, <Ingredient name=\"salt\"  />, <Ingredient name=\"coconut sugar\"  />, and <Ingredient name=\"yeast\" modifier=\"instant\" />.",
          "pause": false
        },
        {
          "text": "Start adding water and mixing until all flour is moist and you have a monotonous mass. (Don’t add all water at once, otherwise, the dough may be too wet.)",
          "pause": false
        },
        {
          "text": "Cover the bowl and leave it in a warm place to let the dough rise, for about 1 hour. (For example, put the bowl into the oven and turn it on at 180C for one minute.)",
          "pause": false
        },
        {
          "text": "Preheat oven to 220C.",
          "pause": false
        },
        {
          "text": "Grease a medium oven-safe glass bowl with butter.",
          "pause": false
        },
        {
          "text": "Transfer the dough into the greased bowl using a silicone spatula.",
          "pause": false
        },
        {
          "text": "Leave the dough uncovered at the top of the preheating oven for 20-30 minutes to let it rise again.",
          "pause": false
        },
        {
          "text": "Bake the bread for 15 minutes.",
          "pause": false
        },
        {
          "text": "Reduce the heat to 190C and bake for 17 minutes more.",
          "pause": false
        },
        {
          "text": "Remove the bread from the oven, and from the bowl. Let it cool down on the cooling rack for 10 minutes before cutting. (If the bread looks pale, bake it for 5 more minutes without a bowl.)",
          "pause": false
        }
      ]
    }
  ],
