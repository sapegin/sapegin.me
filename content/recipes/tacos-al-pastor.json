  "steps": [
    {
      "name": "To cook the meat",
      "steps": [
        {
          "text": "Halve the onion, peel, and slice into 1/2 cm slices.",
          "pause": false
        },
        {
          "text": "Prepare the marinade: juice the oranges, dilute <Ingredient name=\"achiote\"  /> in orange juice, add onions, <Ingredient name=\"dried oregano\"  />, and salt.",
          "pause": false
        },
        {
          "text": "Wash the meat, and cut into 2 cm cubes, add the meat to the marinade, and thoroughly mix.",
          "pause": false
        },
        {
          "text": "Refrigerate the meat overnight in a closed container.",
          "pause": false
        },
        {
          "text": "In a medium-size pot set on medium-high heat, start cooking the meat. Bring to a boil, reduce the heat to medium-low, and cook covered for about 40 minutes, until the meat is soft.",
          "pause": false
        },
        {
          "text": "Heat a bit of olive oil on a medium-size skillet set on medium-high heat, and fry the meat with a bit of juice and onions for about 10 minutes, until it starts to brown a bit.",
          "pause": false
        }
      ]
    },
    {
      "name": "To cook the pineapple",
      "steps": [
        {
          "text": "While the meet is cooking, peel the pineapple, remove the core, and cut it into 1 cm cubes.",
          "pause": false
        },
        {
          "text": "In a medium-sized non-sticking pot, melt the butter.",
          "pause": false
        },
        {
          "text": "Add the pineapple, <Ingredient name=\"coconut sugar\"  />, and <Ingredient name=\"cinnamon\" modifier=\"ground\" />. Stir thoroughly, and cook covered for about 15 minutes, until the pineapple is soft.",
          "pause": false
        },
        {
          "text": "Uncover the pineapples, and cook for about 5 minutes more to reduce the liquid.",
          "pause": false
        }
      ]
    },
    {
      "name": "To serve",
      "steps": [
        {
          "text": "Warm up the tortillas: heat a non-sticking or cast iron skillet on medium-high until hot (don’t add oil). Warm the tortillas one by one: for about 30 seconds on one side, then for about one minute on the other side, then flip again and cook a bit more, until crispy but still slightly flexible (they shouldn’t be too soft because the meat is very juicy, and they may break).",
          "pause": false
        },
        {
          "text": "Serve all the ingredients separately: meat, tortillas, avocado, pineapples, pico de gallo, salsa verde, and pickled onions, so everyone can assemble a taco of their dream.",
          "pause": false
        }
      ]
    }
  ],
