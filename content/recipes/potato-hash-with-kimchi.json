  "overnight": false,
  "slug": "potato-hash-with-kimchi",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Cut the potatoes into 2 cm cubes.",
          "pause": false
        },
        {
          "text": "Put the potatoes into a medium pot, fill with water, add <Ingredient name=\"bay leaf\"  />, add a generous amount of salt, and cook until the potatoes are tender.",
          "pause": false
        },
        {
          "text": "While potatoes are cooking, cut bacon into 1/2 cm cubes.",
          "pause": false
        },
        {
          "text": "Transfer the potatoes onto a paper towel to dry.",
          "pause": false
        },
        {
          "text": "Warm up a large skillet on medium-high heat, and fry bacon until it starts to crisp, stirring occasionally.",
          "pause": false
        },
        {
          "text": "Add a tablespoon of butter (more if you don’t use bacon), add the potatoes to the skillet, and fry until they are crisp and brown on all sides, stirring occasionally.",
          "pause": false
        },
        {
          "text": "While the potatoes are cooking, prepare the vegetables. **Onions:** peel, and cut into medium dice. **Garlic:** peel, and cut into medium-size pieces. **Chili:** remove the seeds, and thinly slice. **Bell peppers:** cut into 1x3 cm strips. **Kimchi:** roughly chop.",
          "pause": false
        },
        {
          "text": "Transfer the potatoes to a plate when they are ready.",
          "pause": false
        },
        {
          "text": "Reduce the heat to medium, add olive oil to the skillet if it’s dry, then add the onions, and garlic. Sauté until the onions are transparent.",
          "pause": false
        },
        {
          "text": "Increase the heat a bit, add the kimchi, and bell peppers, and cook for a few minutes.",
          "pause": false
        },
        {
          "text": "Reduce the heat, and cook for about 5 minutes more.",
          "pause": false
        },
        {
          "text": "Add the potatoes back to the skillet, add a bit of kimchi juice, and mix everything.",
          "pause": false
        },
        {
          "text": "Push the vegetables to the sides of the skillet to expose the bottom of the skillet, and break the eggs into the holes, season the eggs with salt and black pepper, and cook until the whites set.",
          "pause": false
        }
      ]
    }
  ],
