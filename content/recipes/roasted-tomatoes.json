      "steps": [
        {
          "text": "Preheat oven to 120C.",
          "pause": false
        },
        {
          "text": "Smash and peel garlic.",
          "pause": false
        },
        {
          "text": "Arrange tomatoes (whole) in a baking form or on a baking tray lined with baking paper.",
          "pause": false
        },
        {
          "text": "Liberally drizzle everything with olive oil, add rosemary; season with salt and black pepper.",
          "pause": false
