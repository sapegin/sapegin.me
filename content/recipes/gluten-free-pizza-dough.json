  "overnight": false,
  "slug": "gluten-free-pizza-dough",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Preheat oven to 180C.",
          "pause": false
        },
        {
          "text": "In a big mixing bowl, mix flours, starch, and yeast using a whisk.",
          "pause": false
        },
        {
          "text": "Add salt, mix again to combine all dry ingredients.",
          "pause": false
        },
        {
          "text": "Add olive oil, 80 g of warm water, and an egg. Mix until a sticky batter forms using a mixer with a paddle attachment on medium-high speed for about five minutes.",
          "pause": false
        },
        {
          "text": "Cover the bowl with the dough and leave it in a warm place (for example on top of the stove with turned on oven) for about 45 minutes or until the dough grows for about 150%.",
          "pause": false
        },
        {
          "text": "Place a sheet of baking paper on a table, sprinkle the paper and your hands with flour, and transfer the dough to the paper. If the dough is too wet and sticky, add more flour to it.",
          "pause": false
        },
        {
          "text": "Roll the dough on the paper and make a thin rectangle of it of the size of your baking tray.",
          "pause": false
        },
        {
          "text": "Transfer the paper onto the baking tray.",
          "pause": false
        },
        {
          "text": "Add the sauce and all the toppings (depending on the pizza you’re cooking).",
          "pause": false
        },
        {
          "text": "Bake for about 25 minutes.",
          "pause": false
        }
      ]
    }
  ],
