  "source": "Our family inherited this wonderful recipe from Margarita’s mom.",
  "steps": [
    {
      "name": "To cook the potato filling",
      "steps": [
        {
          "text": "Peel the potatoes.",
          "pause": false
        },
        {
          "text": "In a medium-size pot sat on medium-high heat, cook the potatoes in salty water until tender.",
          "pause": false
        },
        {
          "text": "Cool down the potatoes.",
          "pause": false
        },
        {
          "text": "Mash the potatoes using a masher.",
          "pause": false
        },
        {
          "text": "Grind the Emmental cheese, crumble the Feta cheese, add them to the potatoes and thoroughly mix.",
          "pause": false
        },
        {
          "text": "Add more salt if needed.",
          "pause": false
        }
      ]
    },
    {
      "name": "To cook the tacos dorados",
      "steps": [
        {
          "text": "Warm up the tortillas on a skillet, until soft (they should be flexible enough to be rolled).",
          "pause": false
        },
        {
          "text": "Put about a tablespoonful of the filling in the middle-low part of the tortilla, and tightly roll it.",
          "pause": false
        },
        {
          "text": "Repeat for as many times as you have filling for.",
          "pause": false
        },
        {
          "text": "Preheat oven to 210C (skip this step if using an air fryer).",
          "pause": false
        },
        {
          "text": "Arrange the tacos on a baking sheet (or in the air fryer basket) and bake for about 25 minutes in the oven (or for about 12 minutes in the air fryer at 200C), until very crispy.",
          "pause": false
        }
      ]
    },
    {
      "name": "To serve the tacos dorados",
      "steps": [
        {
          "text": "Cook [salsa de jitomate](/recipes/salsa-de-jitomate).",
          "pause": false
        },
        {
          "text": "Cook [salsa de chile de árbol](/recipes/salsa-de-chile-de-arbol).",
          "pause": false
        },
        {
          "text": "Thinly slice the iceberg salad.",
          "pause": false
        },
        {
          "text": "Serve the tacos dorados topped with the smetana, iceberg salad, and salsas.",
          "pause": false
        }
      ]
    }
  ],
