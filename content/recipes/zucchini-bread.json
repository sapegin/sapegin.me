  "slug": "zucchini-bread",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Preheat oven to 155C.",
          "pause": false
        },
        {
          "text": "In a medium-size bowl, mix all dry ingredients: flour, nutmeg, salt, and baking powder using a whisk.",
          "pause": false
        },
        {
          "text": "Grate zucchini on a small side of a grater, use the smaller end of zucchini to make short pieces. Grate a bit of ginger on a small side of a grater (you could mix it with the zucchini). Make sure zucchini is not wet, otherwise, squeeze it to remove the moisture.",
          "pause": false
        },
        {
          "text": "In a big mixer bowl, mix in eggs into the olive oil one by one, using a mixer.",
          "pause": false
        },
        {
          "text": "Mix in dry ingredients.",
          "pause": false
        },
        {
          "text": "Mix in zucchini and ginger into the egg-oil mix, using a silicone spatula.",
          "pause": false
        },
        {
          "text": "Pour the batter into a baking form.",
          "pause": false
        },
        {
          "text": "Add some sunflower and sesame seeds on top.",
          "pause": false
        },
        {
          "text": "Bake for 50-60 minutes.",
          "pause": false
        },
        {
          "text": "Let the bread cool down for 10 minutes, and remove it from the baking form.",
          "pause": false
        }
      ]
    }
  ],
