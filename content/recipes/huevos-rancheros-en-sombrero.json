  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Warm a skillet on medium heat with a bit of olive oil.",
          "pause": false
        },
        {
          "text": "Crack an egg on one half of a skillet, and put a tortilla on the other half.",
          "pause": false
        },
        {
          "text": "Sprinkle a bit of salt over the egg.",
          "pause": false
        },
        {
          "text": "Flip the tortilla after about one minute, then flip it again after about 30 seconds.",
          "pause": false
        },
        {
          "text": "Spread the beans on top of the tortilla, place an egg on top of the beans, and cook until the tortilla is a bit crispy on the bottom.",
          "pause": false
        },
        {
          "text": "Serve topped with salsa roja tatemada and guacamole.",
          "pause": false
        }
      ]
    }
