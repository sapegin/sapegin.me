  "slug": "eggplant-cream-soup",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Preheat oven to 200C.",
          "pause": false
        },
        {
          "text": "Slice an onion in halves. Put all the vegetables unpeeled into a baking form, pour a bit of olive oil on top, add salt and black pepper.",
          "pause": false
        },
        {
          "text": "Bake for 20-30 minutes, until vegetables are soft when you stab them with a knife or a fork.",
          "pause": false
        },
        {
          "text": "When the vegetables cooled down a bit, take them out of the baking form (don’t wash the baking form, we'll need it later). Peel the onion, the eggplants, and the pepper. Roughly chop them into big chunks and puree using a blender or a food processor until you have a smooth creamy paste.",
          "pause": false
        },
        {
          "text": "Pour 400-500 g of hot chicken stock into the baking form from the vegetables, add a teaspoon of curry powder. Mix until the powder has diluted.",
          "pause": false
        },
        {
          "text": "Pour the vegetable puree and the broth into a small pan. Add two bay leaves. Add a teaspoon of ground cumin. Stir, and cook on low heat for 10 minutes.",
          "pause": false
        },
        {
          "text": "Grate a bit of Parmigiano-Reggiano over the soup and stir.",
          "pause": false
        },
        {
          "text": "Serve with thinly chopped olives and green onion.",
          "pause": false
        }
      ]
    }
  ],
