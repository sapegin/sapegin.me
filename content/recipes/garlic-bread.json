  "slug": "garlic-bread",
  "steps": [
    {
      "name": "To make the butter",
      "steps": [
        {
          "text": "Finely chop parsley.",
          "pause": false
        },
        {
          "text": "Put butter and parsley into a medium-sized bowl.",
          "pause": false
        },
        {
          "text": "Press the garlic into the bowl.",
          "pause": false
        },
        {
          "text": "Grate Parmigiano Reggiano into the bowl.",
          "pause": false
        },
        {
          "text": "Season with black pepper.",
          "pause": false
        },
        {
          "text": "Thoroughly mix all the ingredients.",
          "pause": false
        }
      ]
    },
    {
      "name": "To make the bread",
      "steps": [
        {
          "text": "Preheat oven to 200C.",
          "pause": false
        },
        {
          "text": "Halve the bread lengthwise.",
          "pause": false
        },
        {
          "text": "Spread the garlic butter on both halves of the bread, coating the whole area (put a bit more in the middle so melting butter soaks the bread but doesn’t drip too much from the edges).",
          "pause": false
        },
        {
          "text": "Put the bread on a grid, and put a baking tray under (there should be something to catch the dripping butter, otherwise it’ll burn on the bottom of the oven).",
          "pause": false
        },
        {
          "text": "Bake for 10-20 minutes, until golden. (If the bread was just baked and still hot, 7-10 minutes should be enough.)",
          "pause": false
        }
      ]
    }
  ],
