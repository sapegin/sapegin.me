  "overnight": false,
  "slug": "morning-crunch-granola",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Preheat oven to 160C. Line a baking sheet with parchment paper.",
          "pause": false
        },
        {
          "text": "In a small saucepan, put <Ingredient name=\"coconut oil\"  />, <Ingredient name=\"maple syrup\"  />, <Ingredient name=\"salt\"  />.",
          "pause": false
        },
        {
          "text": "Place on medium heat, and stir until the coconut oil is melted.",
          "pause": false
        },
        {
          "text": "In a large bowl, combine <Ingredient name=\"oat\"  />, and the coconut oil mixture. Mix well, until every oat is lightly coated.",
          "pause": false
        },
        {
          "text": "Coarsely chop the nuts, and add them to the oats. Mix again.",
          "pause": false
        },
        {
          "text": "Evenly distribute the granola on the baking sheet using a silicone spatula or a large spoon.",
          "pause": false
        },
        {
          "text": "Bake for 10 minutes.",
          "pause": false
        },
        {
          "text": "Stir, and bake for another 10-15 minutes, until light-golden and a bit crispy but not dark.",
          "pause": false
        },
        {
          "text": "Let the granola cool completely.",
          "pause": false
        },
        {
          "text": "Cut the dried fruits into small pieces, and mix them with the granola.",
          "pause": false
        }
      ]
    }
  ],
