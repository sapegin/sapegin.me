  "notes": [
    "The amounts of ingredients are average and depend on the quality of ingredients, and the age of the chickpeas. You need to taste the hummus and adjust the amounts every time."
  ],
  "overnight": true,
  "slug": "hummus",
  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "Soak the chickpeas in water overnight.",
          "pause": true
        },
        {
          "text": "Cook the chickpeas in water and a generous amount of salt on medium heat until tender.",
          "pause": false
        },
        {
          "text": "While the chickpeas are cooking, peel and roughly chop the garlic.",
          "pause": false
        },
        {
          "text": "When the chickpeas are cooked, discard the water.",
          "pause": false
        },
        {
          "text": "In a food processor or a mixer, put the chickpeas, tahini paste, zest and juice the lime, and olive oil (start with half of the amount).",
          "pause": false
        },
        {
          "text": "Mix until you have a uniform paste.",
          "pause": false
        },
        {
          "text": "Add more lime juice or olive oil if the hummus is too dry. Season with salt and black pepper.",
          "pause": false
        }
      ]
    }
  ],
