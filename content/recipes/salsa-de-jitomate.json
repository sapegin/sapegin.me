  "steps": [
    {
      "name": "",
      "steps": [
        {
          "text": "In a saucepan sat on medium-high heat, cook the tomatoes with cinnamon and cloves in water (the water should cover around half of the height of the tomatoes) until the tomatoes start to soften.",
          "pause": false
        },
        {
          "text": "While the tomatoes are cooking, peel the onion, halve it and thinly slice.",
          "pause": false
        },
        {
          "text": "Let the tomatoes cool down a bit.",
          "pause": false
        },
        {
          "text": "Blend the tomatoes in a blender with a bit of cinnamon (discard the rest), cloves, a pinch of salt, and a bit of cooking water.",
          "pause": false
        },
        {
          "text": "Add more cooking water and salt if needed to reach the desired thickness.",
          "pause": false
        },
        {
          "text": "Add the onions to the salsa.",
          "pause": false
        }
      ]
    }
  ],
