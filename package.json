{
  "name": "sapegin",
  "type": "module",
  "private": true,
  "license": "See license in <Readme.md>",
  "scripts": {
    "dev:sapegin": "astro dev --root ./sites/sapegin.me",
    "dev:sapegin:sqrlsng": "SQRLSNG_DIR=../squirrelsong astro dev --root ./sites/sapegin.me",
    "dev:morning": "astro dev --root ./sites/morning.photos",
    "dev:tacohuaco": "astro dev --root ./sites/tacohuaco",
    "build:sapegin": "astro build --root ./sites/sapegin.me",
    "build:morning": "astro build --root ./sites/morning.photos",
    "build:tacohuaco": "astro build --root ./sites/tacohuaco",
    "preview:sapegin": "astro preview --root ./sites/sapegin.me",
    "preview:morning": "astro preview --root ./sites/morning.photos",
    "preview:tacohuaco": "astro preview --root ./sites/tacohuaco",
    "astro-sync:sapegin": "astro sync --root ./sites/sapegin.me",
    "astro-sync:morning": "astro sync --root ./sites/morning.photos",
    "astro-sync:tacohuaco": "astro sync --root ./sites/tacohuaco",
    "check:sapegin": "astro check --root ./sites/sapegin.me",
    "check:morning": "astro check --root ./sites/morning.photos",
    "check:tacohuaco": "astro check --root ./sites/tacohuaco",
    "lint:js": "eslint . --cache --fix",
    "lint:text": "textlint \"content/blog/*.md\"",
    "lint:text:fix": "npm run lint:text -- --fix",
    "format": "prettier --log-level warn --write \"**/*.{js,cjs,mjs,ts,tsx,astro,css,json,md}\"",
    "test": "npm run check:sapegin && npm run check:morning && npm run check:tacohuaco && npm run lint:js && npm run lint:text",
    "posttest": "npm run format",
    "sync:sapegin": "node --experimental-strip-types scripts/sync-book.ts; node --experimental-strip-types scripts/sync-squirrelsong.ts",
    "sync:morning": "node --experimental-strip-types scripts/sync-photos.ts",
    "sync:tacohuaco": "node --experimental-strip-types scripts/tacohuaco/sync.ts",
    "sync": "npm run sync:sapegin && npm run sync:morning",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.11.0",
  "browserslist": [
    ">1%",
    "last 1 version",
    "Firefox ESR",
    "not dead"
  ],
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "4.2.2",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.2.14",
    "astro": "^6.1.2",
    "astro-og-canvas": "^0.11.0",
    "clsx": "2.1.1",
    "downshift": "9.3.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "lodash": "^4.17.21",
    "lunr": "2.3.9",
    "markdown-it": "^14.1.1",
    "markdown-to-jsx": "^9.7.13",
    "match-sorter": "8.2.0",
    "nano-staged": "0.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "remove-markdown": "0.6.3",
    "richtypo": "^7.0.1",
    "sanitize-html": "^2.17.2",
    "shiki": "^4.0.2",
    "strip-json-comments": "^5.0.3",
    "tailwindcss": "4.2.2",
    "tamia": "^7.2.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/markdown": "^8.0.1",
    "@types/lunr": "2.3.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "24.10.1",
    "@types/remove-markdown": "0.3.4",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9.39.1",
    "eslint-config-tamia": "^9.9.1",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-better-tailwindcss": "4.3.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "exifreader": "4.38.0",
    "husky": "^9.1.7",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "textlint": "^15.5.2",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-apostrophe": "^3.0.0",
    "textlint-rule-common-misspellings": "^1.0.1",
    "textlint-rule-diacritics": "^2.1.4",
    "textlint-rule-no-dead-link": "^6.2.1",
    "textlint-rule-stop-words": "^5.2.0",
    "textlint-rule-terminology": "^5.2.16",
    "textlint-rule-write-good": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.4"
  },
  "nano-staged": {
    "*.{js,cjs,mjs,ts,tsx,astro,css,json,md}": "prettier --write",
    "*.{js,cjs,mjs,ts,tsx,astro}": "eslint --cache --fix"
  }
}
