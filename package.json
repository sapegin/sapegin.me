{
  "name": "sapegin",
  "type": "module",
  "private": true,
  "license": "See license in <Readme.md>",
  "scripts": {
    "start:sapegin": "SITE=sapegin.me astro dev",
    "start:sapegin-sqrlsng": "SQRLSNG_DIR=../squirrelsong SITE=sapegin.me astro dev",
    "dev:sapegin": "SITE=sapegin.me astro dev",
    "prebuild": "npm run sync",
    "build:sapegin": "SITE=sapegin.me astro build",
    "preview:sapegin": "SITE=sapegin.me astro preview",
    "astro": "astro",
    "lint": "npm run lint:sapegin && npm run lint:text",
    "lint:sapegin": "SITE=sapegin.me astro sync && eslint . --cache --fix",
    "lint:text": "textlint \"content/blog/*.md\"",
    "lint:text:fix": "npm run lint:text -- --fix",
    "format": "prettier --log-level warn --write \"**/*.{js,cjs,mjs,ts,tsx,astro,css,json,md}\"",
    "pretest": "npm run lint",
    "test": "astro check",
    "sync": "node --experimental-strip-types scripts/sync-book.ts; node --experimental-strip-types scripts/sync-squirrelsong.ts",
    "posttest": "npm run format",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "browserslist": [
    ">1%",
    "last 1 version",
    "Firefox ESR",
    "not dead"
  ],
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "4.2.2",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.2.14",
    "astro": "^6.1.2",
    "astro-og-canvas": "^0.11.0",
    "clsx": "2.1.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "lodash": "^4.17.21",
    "markdown-it": "^14.1.1",
    "markdown-to-jsx": "^9.7.13",
    "nano-staged": "0.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "richtypo": "^7.0.1",
    "sanitize-html": "^2.17.2",
    "shiki": "^4.0.2",
    "strip-json-comments": "^5.0.3",
    "tailwindcss": "4.2.2",
    "tamia": "^7.2.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/markdown": "^8.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "24.10.1",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9.39.1",
    "eslint-config-tamia": "^9.9.1",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-better-tailwindcss": "4.3.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "textlint": "^15.5.2",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-apostrophe": "^3.0.0",
    "textlint-rule-common-misspellings": "^1.0.1",
    "textlint-rule-diacritics": "^2.1.4",
    "textlint-rule-no-dead-link": "^6.2.1",
    "textlint-rule-stop-words": "^5.2.0",
    "textlint-rule-terminology": "^5.2.16",
    "textlint-rule-write-good": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "nano-staged": {
    "*.{js,cjs,mjs,ts,tsx,astro,css,json,md}": "prettier --write",
    "*.{js,cjs,mjs,ts,tsx,astro}": "eslint --cache --fix"
  }
}
