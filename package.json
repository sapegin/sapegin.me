{
  "name": "sapegin",
  "private": true,
  "license": "See license in <Readme.md>",
  "type": "module",
  "scripts": {
    "dev:sapegin": "astro dev --root ./sites/sapegin.me",
    "dev:morning": "astro dev --root ./sites/morning.photos",
    "dev:tacohuaco": "astro dev --root ./sites/tacohuaco",
    "build:sapegin": "astro build --root ./sites/sapegin.me",
    "build:morning": "astro build --root ./sites/morning.photos",
    "build:tacohuaco": "astro build --root ./sites/tacohuaco",
    "preview:sapegin": "astro preview --root ./sites/sapegin.me",
    "preview:morning": "astro preview --root ./sites/morning.photos",
    "preview:tacohuaco": "astro preview --root ./sites/tacohuaco",
    "astro-sync:sapegin": "astro sync --root ./sites/sapegin.me",
    "astro-sync:morning": "astro sync --root ./sites/morning.photos",
    "astro-sync:tacohuaco": "astro sync --root ./sites/tacohuaco",
    "check:sapegin": "astro check --root ./sites/sapegin.me",
    "check:morning": "astro check --root ./sites/morning.photos",
    "check:tacohuaco": "astro check --root ./sites/tacohuaco",
    "lint:js": "oxlint --fix",
    "format": "oxfmt && prettier --write \"sites/**/*.astro\"",
    "test": "npm run check:sapegin && npm run check:morning && npm run check:tacohuaco && npm run lint:js",
    "posttest": "npm run format",
    "sync:sapegin": "node --experimental-strip-types scripts/sync-book.ts; node --experimental-strip-types scripts/sync-squirrelsong.ts; node --experimental-strip-types scripts/sync-blog.ts",
    "sync:morning": "node --experimental-strip-types scripts/sync-photos.ts",
    "sync:tacohuaco": "node --experimental-strip-types scripts/sync-recipes.ts",
    "sync": "npm run sync:sapegin && npm run sync:morning",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "4.2.2",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.2.14",
    "astro": "^6.1.2",
    "astro-og-canvas": "^0.11.0",
    "clsx": "2.1.1",
    "downshift": "9.3.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast": "0.0.2",
    "image-size": "^2.0.2",
    "lodash": "^4.17.21",
    "lunr": "2.3.9",
    "markdown-it": "^14.1.1",
    "markdown-to-jsx": "^9.7.13",
    "match-sorter": "8.2.0",
    "mdast": "2.3.2",
    "mdast-util-to-hast": "^13.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "remove-markdown": "0.6.3",
    "richtypo": "^8.0.0",
    "sanitize-html": "^2.17.2",
    "shiki": "^4.0.2",
    "strip-json-comments": "^5.0.3",
    "tailwindcss": "4.2.2",
    "tamia": "8.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@oxlint/plugins": "1.68.0",
    "@types/lunr": "2.3.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "24.10.1",
    "@types/remove-markdown": "0.3.4",
    "@types/sanitize-html": "^2.16.1",
    "exifreader": "4.38.0",
    "husky": "^9.1.7",
    "nano-staged": "1.0.2",
    "oxfmt": "0.58",
    "oxlint": "1.73",
    "oxlint-config-raccoon": "10.7.0",
    "oxlint-tailwindcss": "1.3.4",
    "oxlint-tsgolint": "0.24.0",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "nano-staged": {
    "*.{js,cjs,mjs,ts,tsx,css,json,md}": "oxfmt",
    "*.astro": "prettier --write",
    "*.{js,cjs,mjs,ts,tsx,astro}": "oxlint --fix"
  },
  "browserslist": [
    ">1%",
    "last 1 version",
    "Firefox ESR",
    "not dead"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.11.0",
  "allowScripts": {
    "esbuild@0.27.7": true,
    "exifreader@4.38.0": true,
    "fsevents@2.3.3": true,
    "fsevents@1.2.13": true,
    "sharp@0.34.4": true
  }
}
